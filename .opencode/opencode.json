{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@0.0.76"],
      "enabled": true,
      "environment": {
        "BROWSER": "chromium"
      }
    },
    "xcodebuild": {
      "type": "local",
      "command": ["npx", "-y", "xcodebuildmcp@2.6.2", "mcp"],
      "enabled": true,
      "timeout": 60000
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "oauth": false
    },
    "sentry": {
      "type": "remote",
      "url": "https://mcp.sentry.dev/mcp",
      "enabled": true
    }
  }
}
