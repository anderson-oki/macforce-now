# Optional panel overrides. Install scripts create /etc/macforce-now/remote-coop-panel.env when absent.
MACFORCE_NOW_REMOTE_COOP_PANEL_BIND_HOST=0.0.0.0
MACFORCE_NOW_REMOTE_COOP_PANEL_PORT=32187
MACFORCE_NOW_REMOTE_COOP_PANEL_ALLOWED_GROUPS=macforce-now-coop-admin
MACFORCE_NOW_REMOTE_COOP_PANEL_UPDATE_AUTOMATIC=1
MACFORCE_NOW_REMOTE_COOP_PANEL_UPDATE_INTERVAL_SECONDS=300
MACFORCE_NOW_REMOTE_COOP_PANEL_UPDATE_VALIDATE=node RemoteCoOp/run-servers.mjs --dry-run

# Remote Co-Op server defaults used by the managed child process.
MACFORCE_NOW_REMOTE_COOP_PUBLIC_HOST=198.12.95.48
MACFORCE_NOW_REMOTE_COOP_PORT=32188
MACFORCE_NOW_REMOTE_COOP_TURN_PORT=32189
MACFORCE_NOW_REMOTE_COOP_TURN_TLS_PORT=32443
MACFORCE_NOW_REMOTE_COOP_TURN_MIN_PORT=42160
MACFORCE_NOW_REMOTE_COOP_TURN_MAX_PORT=42200
MACFORCE_NOW_REMOTE_COOP_AUTOSTART=1

# Production deployments should keep this stable. Install scripts generate it when absent.
MACFORCE_NOW_REMOTE_COOP_TURN_SHARED_SECRET=replace-with-long-random-secret
