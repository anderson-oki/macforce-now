# Optional panel overrides. Install scripts create /etc/opennow/remote-coop-panel.env when absent.
OPENNOW_REMOTE_COOP_PANEL_BIND_HOST=0.0.0.0
OPENNOW_REMOTE_COOP_PANEL_PORT=32187
OPENNOW_REMOTE_COOP_PANEL_ALLOWED_GROUPS=opennow-coop-admin
OPENNOW_REMOTE_COOP_PANEL_UPDATE_AUTOMATIC=1
OPENNOW_REMOTE_COOP_PANEL_UPDATE_INTERVAL_SECONDS=300
OPENNOW_REMOTE_COOP_PANEL_UPDATE_VALIDATE=node RemoteCoOp/run-servers.mjs --dry-run

# Remote Co-Op server defaults used by the managed child process.
OPENNOW_REMOTE_COOP_PUBLIC_HOST=198.12.95.48
OPENNOW_REMOTE_COOP_PORT=32188
OPENNOW_REMOTE_COOP_TURN_PORT=32189
OPENNOW_REMOTE_COOP_TURN_TLS_PORT=32443
OPENNOW_REMOTE_COOP_TURN_MIN_PORT=42160
OPENNOW_REMOTE_COOP_TURN_MAX_PORT=42200
OPENNOW_REMOTE_COOP_AUTOSTART=1

# Production deployments should keep this stable. Install scripts generate it when absent.
OPENNOW_REMOTE_COOP_TURN_SHARED_SECRET=replace-with-long-random-secret
